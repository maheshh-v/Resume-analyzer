# --- Database ---
# Production: Supabase Postgres connection string (Session Pooler recommended), asyncpg driver.
# Example: postgresql+asyncpg://postgres:[password]@[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recruit
# Local dev without Postgres installed: sqlite+aiosqlite:///./dev.db

# --- Supabase (Auth + Storage) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
# Admin-level service role key — SERVER-SIDE ONLY. Never commit a real value; put it in .env only.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes
# Private bucket for white-label branded report PDFs (create it manually in Supabase — see HANDOFF).
SUPABASE_REPORTS_BUCKET=recruitx-reports
# Force local-disk storage even when Supabase is set (local dev/testing without creds).
USE_LOCAL_STORAGE=false

# --- LLM providers ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Note: Gemini 2.x models 404 for API keys created after ~2026 ("no longer available to
# new users") even though they still appear in the models list.
GEMINI_MODEL=gemini-3.5-flash
# Tried automatically (with the same API key) when the primary model is overloaded after
# retries. Leave empty to disable the fallback.
GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- GitHub (optional evidence source) ---
GITHUB_TOKEN=

# --- Langfuse (observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Evidence connectors (optional, off by default) ---
ENABLE_SEMANTIC_SCHOLAR=false
ENABLE_GOOGLE_PATENTS=false
ENABLE_PACKAGE_OWNERSHIP=false

# --- White-label public API ---
PUBLIC_API_RATE_LIMIT_PER_MIN=10

# --- Billing (Stripe metered — scaffold; no charges without a customer + this key) ---
STRIPE_API_KEY=
STRIPE_METER_EVENT_NAME=recruitx_verification

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
INTERVIEW_TOKEN_TTL_HOURS=72
# Applications/minute accepted per public apply link (0 disables the limit).
APPLY_RATE_LIMIT_PER_MIN=10
